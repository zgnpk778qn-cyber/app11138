#:kivy 2.0

<MainScreen>:
    name: 'main'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(10)

        # 标题栏
        BoxLayout:
            size_hint_y: 0.08
            spacing: dp(10)
            Label:
                text: 'AutoClicker'
                font_size: '24sp'
                bold: True
                size_hint_x: 0.5
                halign: 'left'
                text_size: self.size
            BoxLayout:
                size_hint_x: 0.5
                orientation: 'horizontal'
                spacing: dp(5)
                Canvas:
                    Color:
                        rgba: root.status_color
                    Ellipse:
                        pos: self.pos
                        size: (dp(12), dp(12))
                Label:
                    text: root.status_text
                    font_size: '16sp'
                    color: root.status_color

        # 控制按钮行
        BoxLayout:
            size_hint_y: 0.08
            spacing: dp(5)
            Button:
                id: btn_start
                text: '开始 (3s)'
                background_color: (0.2, 0.8, 0.2, 1)
                font_size: '15sp'
                on_press: root.start_with_countdown()
            Button:
                text: '暂停'
                background_color: (0.8, 0.8, 0.2, 1)
                on_press: root.pause_auto()
            Button:
                text: '继续'
                background_color: (0.2, 0.5, 0.8, 1)
                on_press: root.resume_auto()
            Button:
                text: '停止'
                background_color: (0.8, 0.2, 0.2, 1)
                on_press: root.stop_auto()

        # 倒计时标签
        Label:
            id: countdown_label
            text: ''
            font_size: '40sp'
            bold: True
            color: (1, 1, 0, 1)
            size_hint_y: 0.06
            opacity: 0

        # 设置入口
        BoxLayout:
            size_hint_y: 0.06
            spacing: dp(5)
            Button:
                text: '特征设置'
                background_color: (0.3, 0.3, 0.5, 1)
                size_hint_x: 0.35
                on_press: root.open_feature_settings()
            Button:
                text: '系统配置'
                background_color: (0.4, 0.4, 0.4, 1)
                size_hint_x: 0.35
                on_press: app.root.current = 'config'
            Label:
                text: ''
                size_hint_x: 0.3

        # 状态信息
        BoxLayout:
            size_hint_y: 0.05
            spacing: dp(20)
            Label:
                text: '翻页次数:'
                size_hint_x: 0.3
            Label:
                text: str(root.scroll_count)
                size_hint_x: 0.2
                bold: True
            Label:
                text: '最近操作:'
                size_hint_x: 0.2
            Label:
                text: root.last_action
                size_hint_x: 0.3
                text_size: self.size
                shorten: True

        # 日志区域
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.55
            BoxLayout:
                size_hint_y: 0.1
                spacing: dp(5)
                Label:
                    text: '运行日志'
                    font_size: '16sp'
                    bold: True
                    size_hint_x: 0.7
                    halign: 'left'
                    text_size: self.size
                Button:
                    text: '清空'
                    size_hint_x: 0.3
                    on_press: root.clear_log()
            ScrollView:
                size_hint_y: 0.9
                TextInput:
                    id: log_display
                    text: root.log_text
                    readonly: True
                    font_size: '12sp'
                    background_color: (0.1, 0.1, 0.1, 1)
                    foreground_color: (0, 1, 0, 1)
                    font_name: 'Consolas'

        # 底部提示
        Label:
            size_hint_y: 0.03
            text: '确保已连接设备并授予必要权限 | 特征设置可配置点击目标'
            font_size: '10sp'
            color: (0.5, 0.5, 0.5, 1)


<ConfigScreen>:
    name: 'config'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(15)
        spacing: dp(8)
        BoxLayout:
            size_hint_y: 0.07
            spacing: dp(10)
            Label:
                text: '系统配置'
                font_size: '22sp'
                bold: True
                size_hint_x: 0.6
                halign: 'left'
                text_size: self.size
            Button:
                text: '返回'
                size_hint_x: 0.2
                on_press: app.root.current = 'main'
            Button:
                text: '保存'
                size_hint_x: 0.2
                background_color: (0.2, 0.6, 0.2, 1)
                on_press: root.save_config()

        ScrollView:
            size_hint_y: 0.93
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
                padding: dp(10)

                Label:
                    text: '颜色检测'
                    font_size: '16sp'
                    bold: True
                    size_hint_y: None
                    height: dp(30)
                    halign: 'left'
                    text_size: self.size

                GridLayout:
                    cols: 2
                    size_hint_y: None
                    height: dp(40)
                    spacing: dp(5)
                    Label:
                        text: '默认检测颜色:'
                    Spinner:
                        id: color_spinner
                        text: '红色'
                        on_text: root.on_color_selected(self, self.text)

                Label:
                    text: '时间参数'
                    font_size: '16sp'
                    bold: True
                    size_hint_y: None
                    height: dp(30)
                    halign: 'left'
                    text_size: self.size

                GridLayout:
                    cols: 2
                    size_hint_y: None
                    height: dp(160)
                    spacing: dp(5)
                    Label:
                        text: '检测间隔(秒):'
                    TextInput:
                        id: interval_input
                        text: '1.0'
                        multiline: False
                        input_filter: 'float'
                    Label:
                        text: '翻页后等待(秒):'
                    TextInput:
                        id: scroll_interval_input
                        text: '2.0'
                        multiline: False
                        input_filter: 'float'
                    Label:
                        text: '空周期停止阈值:'
                    TextInput:
                        id: max_empty_cycles_input
                        text: '3'
                        multiline: False
                        input_filter: 'int'
                    Label:
                        text: '翻页方向:'
                    Spinner:
                        id: scroll_direction_spinner
                        text: '上滑(看下方内容)'
                        values: ['上滑(看下方内容)', '下滑(看上方内容)']
                        on_text: root.set_scroll_direction(self.text)

                Label:
                    text: '连接设置'
                    font_size: '16sp'
                    bold: True
                    size_hint_y: None
                    height: dp(30)
                    halign: 'left'
                    text_size: self.size

                GridLayout:
                    cols: 2
                    size_hint_y: None
                    height: dp(40)
                    spacing: dp(5)
                    Label:
                        text: '后端模式:'
                    Spinner:
                        id: backend_spinner
                        text: app.config_data.get('backend', 'mock')
                        values: ['mock', 'adb', 'android']
                        on_text: root.set_backend(self.text)

                GridLayout:
                    cols: 2
                    size_hint_y: None
                    height: dp(40)
                    spacing: dp(5)
                    Label:
                        text: 'ADB 设备号:'
                    TextInput:
                        id: adb_device_input
                        text: app.config_data.get('adb_device', '')
                        multiline: False
                        hint_text: '留空使用默认设备'
                        on_text: app.config_data['adb_device'] = self.text


<FeatureConfigScreen>:
    name: 'feature_config'
    BoxLayout:
        orientation: 'vertical'
        padding: dp(15)
        spacing: dp(8)
        BoxLayout:
            size_hint_y: 0.07
            spacing: dp(10)
            Label:
                text: '点击目标特征设置'
                font_size: '22sp'
                bold: True
                size_hint_x: 0.5
                halign: 'left'
                text_size: self.size
            Button:
                text: '返回'
                size_hint_x: 0.25
                on_press: root.go_back()
            Button:
                text: '保存'
                size_hint_x: 0.25
                background_color: (0.2, 0.6, 0.2, 1)
                on_press: root.save_features()

        Label:
            text: '设置需要自动点击的目标：颜色 + 文字组合。留空表示不限制该项。'
            font_size: '12sp'
            color: (0.6, 0.6, 0.6, 1)
            size_hint_y: None
            height: dp(30)
            halign: 'left'
            text_size: self.size

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(5)
            Label:
                text: '快速添加:'
                size_hint_x: 0.25
                font_size: '13sp'
            Button:
                text: '红色按钮'
                size_hint_x: 0.25
                font_size: '11sp'
                background_color: (0.6, 0.2, 0.2, 1)
                on_press: root.add_preset('红色', '')
            Button:
                text: '绿色确认'
                size_hint_x: 0.25
                font_size: '11sp'
                background_color: (0.2, 0.6, 0.2, 1)
                on_press: root.add_preset('绿色', '确认')
            Button:
                text: '任意色完成'
                size_hint_x: 0.25
                font_size: '11sp'
                background_color: (0.3, 0.3, 0.5, 1)
                on_press: root.add_preset('', '完成')

        ScrollView:
            size_hint_y: 0.7
            BoxLayout:
                id: feature_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(5)
                padding: dp(5)

        BoxLayout:
            size_hint_y: None
            height: dp(40)
            spacing: dp(5)
            Button:
                text: '+ 添加特征'
                background_color: (0.2, 0.5, 0.8, 1)
                on_press: root.add_feature_row()
            Label:
                text: ''
